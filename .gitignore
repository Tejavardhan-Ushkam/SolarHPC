# ============================================================
# .gitignore -- SolarHPC
# ============================================================

# ── Build artefacts ──────────────────────────────────────────
*.o
*.mod
solarhpc
tests/test_two_body
tests/test_hohmann
tests/test_eclipse
tests/test_energy
build.log

# ── Large data files (regenerated by make fetch) ─────────────
data/
!data/.gitkeep

# ── Large trajectory output (can be 100s MB) ─────────────────
results/orbits/orbit_trajectories.csv

# ── Logs ─────────────────────────────────────────────────────
logs/
*.log

# ── Python cache ─────────────────────────────────────────────
__pycache__/
*.pyc
*.pyo
.pytest_cache/

# ── Plot output (generated locally) ──────────────────────────
plots/output/

# ── LaTeX build artefacts ─────────────────────────────────────
docs/paper/*.aux
docs/paper/*.bbl
docs/paper/*.blg
docs/paper/*.log
docs/paper/*.out
docs/paper/*.synctex.gz
docs/paper/*.fls
docs/paper/*.fdb_latexmk
docs/paper/main.pdf

# ── Download packages ─────────────────────────────────────────
*.tar.gz
*.zip

# ── Editor files ─────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# ── DO version-control these result files (small) ───────────
# (use ! to un-ignore specific files inside ignored directories)
!results/benchmarks/
!results/validation/
!results/eclipses/
!results/missions/
!results/run_metadata.txt
!docs/paper/tables/
!docs/paper/main.tex
!docs/paper/bibliography.bib
